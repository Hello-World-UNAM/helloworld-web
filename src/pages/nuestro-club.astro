---
import Layout from '@layouts/Layout.astro';
import clubData from '@data/club.json';

const { team, mission, vision, generalObjective, objectives } = clubData;

const lucideIcons: Record<string, string> = {
  flag: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flag"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>`,
  eye: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>`,
  target: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  trophy: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`,
  code: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-code"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  rocket: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rocket"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-badge-check"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>`,
  globe: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  camera: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`,
  github: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`
};
---

<Layout title="Nuestro Club | Club Hello World" activeNav="nuestro-club">
  <!-- Hero -->
  <section class="contact-hero">
    <h1>Sobre nosotros</h1>
    <p>Conoce quiénes somos, qué nos mueve y hacia dónde vamos como comunidad tecnológica.</p>
    <div class="hero-divider"></div>
  </section>

  <!-- Main content -->
  <div class="club-main">
    <!-- Espaciador para la Animación Intro en Pantallas Grandes -->
    <div class="hero-spacer-desktop"></div>

    <!-- Galería Artística (Scattered Polaroids) -->
    <div class="gallery-responsive-wrapper">
      <div class="scattered-gallery" id="anim-gallery">
        <div class="scattered-photo sp-1">
          <img src="/img/evento1.jpeg" alt="Comunidad Hello World en evento tecnológico" loading="lazy" />
        </div>
        <div class="scattered-photo sp-2">
          <img src="/img/evento2.jpg" alt="Conferencia tecnológica FES Aragón" loading="lazy" />
        </div>
        <div class="scattered-photo sp-3">
          <img src="/img/evento3.jpg" alt="Networking y colaboración en equipo" loading="lazy" />
        </div>
        <div class="scattered-photo sp-4">
          <img src="/img/evento4.jpg" alt="Participación en hackaton nacional" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="container" style="max-width: 900px; position: relative; z-index: 10;">

      <!-- Misión -->
      <div class="section-card">
        <h2><span class="icon" set:html={lucideIcons.flag} /> Misión</h2>
        <p class="mv-declaracion">
          &ldquo;{mission.statement}&rdquo;
        </p>
        <div class="mv-pilares">
          {mission.pillars.map((pillar) => (
            <div class="mv-pilar">
              <span class="mv-pilar-icon" set:html={lucideIcons[pillar.icon]} />
              <h3>{pillar.title}</h3>
              <p>{pillar.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Visión -->
      <div class="section-card">
        <h2><span class="icon" set:html={lucideIcons.eye} /> Visión</h2>
        <p class="mv-declaracion">
          &ldquo;{vision.statement}&rdquo;
        </p>
        <div class="mv-pilares">
          {vision.pillars.map((pillar) => (
            <div class="mv-pilar">
              <span class="mv-pilar-icon" set:html={lucideIcons[pillar.icon]} />
              <h3>{pillar.title}</h3>
              <p>{pillar.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Objetivo General -->
      <div class="section-card">
        <h2><span class="icon" set:html={lucideIcons.target} /> Objetivo General</h2>
        <div class="objetivo-general-block">
          <p>{generalObjective}</p>
        </div>
      </div>

      <!-- Objetivos Específicos -->
      <div class="section-card">
        <h2><span class="icon" set:html={lucideIcons.star} /> Objetivos Específicos</h2>
        <div class="objetivos-grid">
          {objectives.map((obj, i) => (
            <div class="objetivo-item">
              <span class="objetivo-num">{i + 1}</span>
              <div>
                <h3>{obj.title}</h3>
                <p>{obj.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Mesa Directiva -->
      <div class="section-card">
        <h2><span class="icon" set:html={lucideIcons.users} /> Mesa Directiva</h2>
        <div class="directiva-grid">
          {team.map((member) => (
            <div class="flip-card">
              <div class="flip-card-inner">
                <!-- Frente -->
                <div class="flip-card-front">
                  <img class="directiva-avatar" src={member.image} alt={member.name} width="120" height="120" loading="lazy" />
                  <h3>{member.name}</h3>
                  <span>{member.role}</span>
                  <button class="flip-btn-mobile" aria-label="Ver más">+</button>
                </div>
                <!-- Reverso -->
                <div class="flip-card-back">
                  <p class="flip-bio">{member.bio}</p>
                  <div class="flip-socials">
                    {member.github && (
                      <a href={member.github} target="_blank" rel="noopener noreferrer" class="flip-social-link" aria-label="GitHub">
                        <span set:html={lucideIcons.github} /> GitHub
                      </a>
                    )}
                    {member.linkedin && (
                      <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="flip-social-link" aria-label="LinkedIn">
                        <span set:html={lucideIcons.linkedin} /> LinkedIn
                      </a>
                    )}
                    {!member.github && !member.linkedin && (
                      <span class="flip-social-placeholder">
                        <span set:html={lucideIcons.github} />
                        <span set:html={lucideIcons.linkedin} />
                      </span>
                    )}
                  </div>
                  <button class="flip-btn-mobile flip-btn-back" aria-label="Volver">←</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="container" style="max-width: 900px;">
      <div class="cta-section">
        <h2>Proyectando el futuro</h2>
        <p>Formamos a la próxima generación de líderes competitivos en tecnología. Estamos abiertos a colaboraciones, sinergias y retos que pongan a prueba nuestro dominio técnico ante el mundo.</p>
        <div class="cta-actions">
          <a href="/contacto" class="hw-btn hw-btn-primary">Contáctanos ➔</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function initGalleryAnimation() {
    const wrapper = document.querySelector('.gallery-responsive-wrapper') as HTMLElement;
    const hero = document.querySelector('.contact-hero') as HTMLElement;
    const clubMain = document.querySelector('.club-main') as HTMLElement;
    const photos = document.querySelectorAll('.scattered-photo');
    
    if (!wrapper || !hero || !clubMain || photos.length < 4) return;

    // Reset styles si es < 1400px (Mobile/Laptop)
    if (window.innerWidth < 1400) {
      wrapper.style.top = '';
      wrapper.style.height = '';
      photos.forEach((p: any) => {
        p.style.removeProperty('--anim-x');
        p.style.removeProperty('--anim-y');
        p.style.removeProperty('--anim-r');
        p.style.removeProperty('--anim-s');
      });
      return;
    }

    // Calcular la posición y altura dinámicamente para superponer al Hero
    const heroHeight = hero.offsetHeight;
    wrapper.style.top = `-${heroHeight}px`;
    wrapper.style.height = `calc(100% + ${heroHeight}px)`;

    // Waypoints de animación (Start = Fila abierta en el espaciador | End = Espejo simétrico flanqueando)
    const targets = [
      { start: { x: -340, y: 290, r: -6, s: 0.85 }, end: { x: -700, y: 100, r: -6, s: 1 } },
      { start: { x: -120, y: 270, r: 3, s: 0.85 },  end: { x: 700, y: 100, r: 6, s: 1 } },
      { start: { x: 120, y: 280, r: -2, s: 0.85 },  end: { x: -700, y: 420, r: -4, s: 1 } },
      { start: { x: 340, y: 300, r: 5, s: 0.85 },   end: { x: 700, y: 420, r: 4, s: 1 } }
    ];

    function render() {
      if (window.innerWidth < 1400) return;
      
      const scrollY = window.scrollY;
      // Progresión de 0.0 a 1.0 emparejada al tamaño del espaciador (420px)
      let progress = Math.min(1, Math.max(0, scrollY / 420));

      photos.forEach((p: any, i) => {
        const t = targets[i];
        const x = t.start.x + (t.end.x - t.start.x) * progress;
        const y = t.start.y + (t.end.y - t.start.y) * progress;
        const r = t.start.r + (t.end.r - t.start.r) * progress;
        const s = t.start.s + (t.end.s - t.start.s) * progress;
        
        p.style.setProperty('--anim-x', `${x}px`);
        p.style.setProperty('--anim-y', `${y}px`);
        p.style.setProperty('--anim-r', `${r}deg`);
        p.style.setProperty('--anim-s', `${s}`);
      });
    }

    // Agregar el listener de scroll
    window.removeEventListener('scroll', render); // Limpieza por si acaso
    window.addEventListener('scroll', render, { passive: true });
    render(); // Forzar el render inicial
  }

  // Correr el setup al montar y al redimensionar pantalla
  window.addEventListener('DOMContentLoaded', initGalleryAnimation);
  window.addEventListener('resize', initGalleryAnimation);

  // Flip cards: Toggle para móvil (botón + y ←)
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.flip-btn-mobile').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = (e.target as HTMLElement).closest('.flip-card');
        if (card) card.classList.toggle('flipped');
      });
    });
  });
</script>
