---
import Layout from '@layouts/Layout.astro';

// 1. URL de tu Google Sheets (Debe ser el enlace en formato CSV)
const SHEET_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vT9G2UoQcUeike5dOAQrhNV5DnymjGs_ub2O5osy6EWESrCed-P1xk_awukFS9iCPUM4_sL_wQ9WIG9/pub?output=csv";

let participants = [];

try {
  // 2. Obtenemos los datos de Google Sheets
  const res = await fetch(SHEET_CSV_URL);
  if (!res.ok) throw new Error("No se pudo descargar el CSV");
  
  const csvText = await res.text();
  
  // 3. Parsear el CSV: separamos por filas y omitimos vacías
  const rows = csvText.split('\n').filter(row => row.trim() !== '');
  
  // Omitimos la primera fila asumiendo que son los encabezados (Nombre, Puntos)
  const dataRows = rows.slice(1);
  
  participants = dataRows.map(row => {
    // Separamos por coma
    const [name, pts] = row.split(',');
    return {
      name: name ? name.trim() : 'Desconocido',
      pts: pts ? parseInt(pts.trim(), 10) : 0
    };
  });

  if (participants.length === 0) throw new Error("La hoja está vacía");
  
} catch (error) {
  console.error("Error cargando ranking:", error);
  // Datos de fallback mientras configuras el Sheets
  participants = [
    { name: "Esperando conexión a Google Sheets...", pts: 100 },
    { name: "Falta configurar URL", pts: 50 }
  ];
}

const medalColors = ["#c8a96e", "#6eb5c8", "#c86e9a"];

// Ordenar por puntos (mayor a menor)
const sorted = [...participants].sort((a, b) => b.pts - a.pts);
const maxPts = sorted[0]?.pts || 1;
const pct = (pts: number) => Math.round((pts / maxPts) * 100);

// Agrupar por puntos para manejar empates (Compartir Podio)
const groupedByPts = new Map<number, typeof sorted>();
sorted.forEach(p => {
  if (!groupedByPts.has(p.pts)) groupedByPts.set(p.pts, []);
  groupedByPts.get(p.pts)!.push(p);
});

// Extraer los puntajes únicos, ordenados de mayor a menor
const uniquePts = Array.from(groupedByPts.keys()).sort((a, b) => b - a);

// Estructurar el Top 3 de puntajes para el podio
const top3Ranks = [0, 1, 2].map(i => {
  const pts = uniquePts[i];
  if (pts === undefined) return null;
  return { rank: i + 1, pts, participants: groupedByPts.get(pts)! };
});

// El resto de los participantes para la tabla (partiendo del lugar 4)
const restRanks = [];
for (let i = 3; i < uniquePts.length; i++) {
  const pts = uniquePts[i];
  groupedByPts.get(pts)!.forEach(p => {
    restRanks.push({ rank: i + 1, ...p });
  });
}

// Orden visual del podio: 2º — 1º — 3º (DOM order; CSS order rearranges)
const podiumOrder = [1, 0, 2];
---

<Layout title="Ranking | Club Hello World" activeNav="ranking">
  <div class="ranking-section">
    <h1 class="ranking-title">Leaderboard</h1>
    <p class="ranking-subtitle">Nuestros miembros acumulan puntos al completar cursos, certificaciones y eventos. Los más destacados obtienen reconocimientos e incentivos cada semestre.</p>

    <!-- Podio -->
    <div class="podium" id="podium">
      {podiumOrder.map((i) => {
        const group = top3Ranks[i];
        if (!group) return null;
        const color = medalColors[i];
        return (
          <div class={`podium-card rank-${group.rank}`}>
            <div class="podium-medal">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
                <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
                <path d="M4 22h16"/>
                <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
                <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
                <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" fill={color} opacity="0.2"/>
                <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
              </svg>
            </div>
            <div class="podium-pos">#{group.rank}</div>
            <div class="podium-name">
              {group.participants.map(p => p.name).join(' & ')}
            </div>
            <div class="podium-pts">{group.pts} <span>pts</span></div>
            <div class="pts-bar-wrap">
              <div class="pts-bar" data-pct={pct(group.pts)}></div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Tabla -->
    {restRanks.filter(p => p.pts > 0).length > 0 && (
      <div id="ranking-list-section">
        <div id="table-wrap" class="table-collapsed">
          <table class="ranking-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Participante</th>
                <th>Progreso</th>
                <th>Puntos</th>
              </tr>
            </thead>
            <tbody>
              {restRanks.filter(p => p.pts > 0).map((p, i) => (
                <tr class={i >= 2 ? "extra-row" : ""}>
                  <td class="rank-num">#{p.rank}</td>
                  <td class="player-name">{p.name}</td>
                  <td class="bar-cell">
                    <div class="table-bar-wrap">
                      <div class="table-bar" data-pct={pct(p.pts)}></div>
                    </div>
                  </td>
                  <td class="pts-value">{p.pts} pts</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        {restRanks.filter(p => p.pts > 0).length > 2 && (
          <div class="btn-wrap">
            <button id="show-more-btn" class="hw-btn hw-btn-secondary">Ver más miembros ▼</button>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>

<style>
  #table-wrap {
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: max-height;
  }
  .table-collapsed {
    /* Altura por defecto para SSR, JS la ajustará exacto para modo oscuro/claro y móviles */
    max-height: 250px; 
  }
  .btn-wrap {
    text-align: center;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>

<script>
// Animar barras de progreso al cargar
function animateBars() {
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      document.querySelectorAll('.pts-bar, .table-bar').forEach(bar => {
        const hBar = bar as HTMLElement;
        const pct = parseInt(hBar.dataset.pct || '0', 10);
        hBar.style.width = pct + '%';
        
        // Colores: Siempre verde
        hBar.style.backgroundColor = '#22c55e'; // Verde
      });
    });
  });
}

function setupShowMore() {
  const showMoreBtn = document.getElementById('show-more-btn');
  const tableWrap = document.getElementById('table-wrap');
  const table = document.querySelector('.ranking-table');
  const tbody = table?.querySelector('tbody');
  
  if (showMoreBtn && tableWrap && tbody && tbody.children.length > 2) {
    // Calculamos dinámicamente la altura de la cabecera + 2 primeras filas (Responsive friendly)
    const theadHeight = table.querySelector('thead').offsetHeight;
    const row1Height = tbody.children[0].offsetHeight;
    const row2Height = tbody.children[1].offsetHeight;
    
    // Altura base (sumamos 2px por márgenes/borders comunes)
    const exactCollapsedHeight = theadHeight + row1Height + row2Height + 2;
    
    // Iniciamos la altura exacta antes de que el usuario interactúe
    tableWrap.style.maxHeight = `${exactCollapsedHeight}px`;
    
    showMoreBtn.addEventListener('click', () => {
      const isCollapsed = tableWrap.classList.contains('table-collapsed');
      
      if (isCollapsed) {
        // Expandir tabla: sacamos la altura total
        const fullHeight = table.offsetHeight;
        tableWrap.style.maxHeight = `${fullHeight}px`;
        tableWrap.classList.remove('table-collapsed');
        showMoreBtn.textContent = 'Ocultar miembros ▲';
      } else {
        // Colapsar tabla: regresamos a la altura calculada
        tableWrap.style.maxHeight = `${exactCollapsedHeight}px`;
        tableWrap.classList.add('table-collapsed');
        showMoreBtn.textContent = 'Ver más miembros ▼';
      }
    });

    // En caso de que se redimensione la pantalla, corregimos si es necesario
    window.addEventListener('resize', () => {
      if (!tableWrap.classList.contains('table-collapsed')) {
        tableWrap.style.maxHeight = `${table.offsetHeight}px`;
      }
    });
  }
}

document.addEventListener('DOMContentLoaded', () => {
  animateBars();
  setupShowMore();
});
</script>
