---
import Layout from '@layouts/Layout.astro';

const stats = [
  { target: 20, suffix: "+", label: "miembros" },
  { target: 3, suffix: "", label: "hackatones" },
  { target: 4, suffix: "", label: "proyectos en curso" },
  { target: 3, suffix: "", label: "cursos activos" },
];

const termLines = [
  { cls: 'cmd', text: '$ ./hello_world --identity' },
  { cls: 'out', text: '❯ Equipo de alto rendimiento tecnológico · FES Aragón' },
  { cls: 'blank', text: '' },
  { cls: 'cmd', text: '$ ./hello_world --focus' },
  { cls: 'out', text: '❯ Hackatones · Desarrollo · IA · Liderazgo' },
  { cls: 'blank', text: '' },
  { cls: 'cmd', text: '$ ./hello_world --mission' },
  { cls: 'out', text: '❯ "Impulsar la excelencia y competitividad estudiantil"' },
  { cls: 'blank', text: '' },
  { cls: 'cmd', text: '$ ./hello_world --status' },
  { cls: 'out', text: '● ACTIVO  ·  Proyección nacional e internacional' },
];
---

<Layout title="Club Hello World" activeNav="inicio">
  <h1 class="visually-hidden">Club Hello World — FES Aragón UNAM</h1>
  
  <!-- Hero Section Neo-Brutalista -->
  <section class="hw-hero" aria-label="Introducción al club">
    <div class="hw-hero-container">
      <div class="hw-hero-content">
        <div class="hw-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rocket" style="display:inline-block; vertical-align:-3px; margin-right:4px;"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          Temporada 2026-2027
        </div>
        <h2 class="hw-hero-title">
          Liderando<br/>
          <span class="highlight">el mañana.</span>
        </h2>
        <p class="hw-hero-desc">
          Desde la FES Aragón, UNAM, hacia el mundo. Somos la comunidad que forja talento tecnológico de excelencia. Desarrollamos equipos de alto rendimiento listos para innovar, competir y transformar el mundo.
        </p>
        <div class="hw-hero-actions">
          <a href="/contacto" class="hw-btn hw-btn-primary">Contáctanos ➔</a>
          <a href="/nuestro-club" class="hw-btn hw-btn-secondary">Sobre nosotros</a>
        </div>
      </div>
      
      <div class="hw-hero-visuals">
        <div class="hw-stacked-images">
          <div class="hw-img-box hw-img-back">
            <img class="hw-zoomable" data-modal-color="#c4b5fd" style="color: transparent;" src="/img/equipo.webp" alt="Equipo" loading="lazy">
          </div>
          <div class="hw-img-box hw-img-front">
            <img class="hw-zoomable" data-modal-color="#6225e6" style="color: transparent;" src="/img/logoclub2.webp" alt="Club Hello World" fetchpriority="high">
          </div>
          <div class="hw-deco-star">✦</div>
        </div>
      </div>
    </div>
    
    <a href="#hw-showcase" class="hw-scroll-indicator" aria-label="Desplazar a la sección de la consola">
      <span>Descubre la consola</span>
      <div class="hw-scroll-arrow">↓</div>
    </a>
  </section>

  <!-- Terminal + Stats -->
  <section id="hw-showcase" class="hw-showcase">
    <div class="hw-showcase-inner">
      <!-- Terminal animada -->
      <div class="hw-terminal">
        <div class="hw-terminal-bar">
          <span class="hw-dot" style="background:#ff5f57;"></span>
          <span class="hw-dot" style="background:#febc2e;"></span>
          <span class="hw-dot" style="background:#28c840;"></span>
          <span class="hw-terminal-title">hello_world_club — zsh</span>
        </div>
        <div class="hw-terminal-body">
          <div id="hw-terminal-output"></div>
          <span class="hw-cursor" id="hw-cursor">█</span>
        </div>
      </div>

      <!-- Contadores animados -->
      <div class="hw-stats-grid">
        {stats.map((stat) => (
          <div class="hw-stat-card">
            <div class="hw-stat-value">
              <span class="hw-stat-num" data-target={stat.target}>0</span>
              {stat.suffix && <span class="hw-stat-suffix">{stat.suffix}</span>}
            </div>
            <div class="hw-stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modal de Imagen -->
  <div id="hw-image-modal" class="hw-modal" aria-hidden="true">
    <div class="hw-modal-overlay"></div>
    <div class="hw-modal-content">
      <button class="hw-modal-close" aria-label="Cerrar modal">✕</button>
      <img id="hw-modal-img" src="" alt="Zoomed image">
    </div>
  </div>
</Layout>

<script define:vars={{ termLines }}>
// ── Terminal Typewriter ───────────────────────────────────────────────────────
function runTerminal() {
  const output = document.getElementById('hw-terminal-output');
  if (!output) return;

  let lineIdx = 0;

  function typeLine(line, callback) {
    const span = document.createElement('span');
    span.className = 'hw-line ' + line.cls;
    output.appendChild(span);

    if (line.cls === 'blank') {
      setTimeout(callback, 180);
      return;
    }

    let charIdx = 0;
    const charDelay = line.cls === 'cmd' ? 42 : 16;

    function typeChar() {
      if (charIdx < line.text.length) {
        span.textContent += line.text[charIdx++];
        setTimeout(typeChar, charDelay + Math.random() * 18);
      } else {
        span.textContent += '\n';
        setTimeout(callback, line.cls === 'cmd' ? 280 : 120);
      }
    }
    typeChar();
  }

  function nextLine() {
    if (lineIdx >= termLines.length) return;
    typeLine(termLines[lineIdx++], nextLine);
  }

  setTimeout(nextLine, 700);
}

function initTerminalObserver() {
  const terminal = document.querySelector('.hw-terminal');
  if (!terminal) return;

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        runTerminal();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  observer.observe(terminal);
}

// ── Counters (animate on scroll into view) ────────────────────────────────────
function animateCounter(el) {
  const target = parseInt(el.dataset.target, 10);
  const duration = 1400;
  const startTime = performance.now();

  function step(now) {
    const progress = Math.min((now - startTime) / duration, 1);
    const eased = 1 - Math.pow(2, -10 * progress);
    el.textContent = Math.floor(eased * target);
    if (progress < 1) {
      requestAnimationFrame(step);
    } else {
      el.textContent = target;
    }
  }
  requestAnimationFrame(step);
}

function initCounters() {
  const counters = document.querySelectorAll('.hw-stat-num');
  if (!counters.length) return;

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  counters.forEach(el => observer.observe(el));
}

function initImageZoom() {
  const zoomables = document.querySelectorAll('.hw-zoomable');
  const modal = document.getElementById('hw-image-modal');
  const modalImg = document.getElementById('hw-modal-img');
  const closeBtn = document.querySelector('.hw-modal-close');
  const overlay = document.querySelector('.hw-modal-overlay');

  if (!modal || !zoomables.length) return;

  function openModal(src, alt, color) {
    modalImg.src = src;
    modalImg.alt = alt || 'Zoomed image';
    
    const modalContent = document.querySelector('.hw-modal-content');
    if (color) {
      modalContent.style.boxShadow = `12px 12px 0 ${color}`;
      if (color === '#c4b5fd') {
        modalContent.style.padding = '0';
        modalContent.style.background = 'transparent';
      } else {
        modalContent.style.padding = '';
        modalContent.style.background = '';
      }
    } else {
      modalContent.style.boxShadow = '12px 12px 0 #6225e6';
      modalContent.style.padding = '';
      modalContent.style.background = '';
    }

    modal.classList.add('is-active');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-active');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  zoomables.forEach(img => {
    img.addEventListener('click', () => {
      openModal(img.src, img.alt, img.getAttribute('data-modal-color'));
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('is-active')) {
      closeModal();
    }
  });
}

initTerminalObserver();
initCounters();
initImageZoom();
</script>
